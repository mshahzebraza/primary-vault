filters:
  and:
    - file.path.contains("Notes/")
    - file.ext == "md"
    - '!file.name.contains("Template")'
    - tags.contains("journal")
properties:
  file.name:
    displayName: Entry
  note.date:
    displayName: Date
  note.created:
    displayName: Created
views:
  - type: table
    name: Table
    order:
      - file.name
      - date
      - created
    sort:
      - property: file.name
        direction: ASC
