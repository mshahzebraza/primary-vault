filters:
  and:
    - categories.contains(link("Meetings"))
    - file.path.contains("Notes/")
    - file.ext == "md"
    - note["related-tasks"].contains(link(this.file))
properties:
  file.name:
    displayName: Meeting
  note.date:
    displayName: Date
  note.organization:
    displayName: Organization
views:
  - type: table
    name: Related meetings
    order:
      - file.name
      - date
      - organization
    sort:
      - property: date
        direction: DESC
